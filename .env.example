# Escrow (.env.escrow)
# Fund both accounts with sETH from https://faucets.chain.link/arbitrum-sepolia
BUYER_PK=0x_your_buyer_private_key_here
SELLER_PK=0x_your_seller_private_key_here

# Ballot (.env.ballot)
ADMIN_PK=0x_admin_private_key_here
VOTER1_PK=0x_voter1_private_key_here
VOTER2_PK=0x_voter2_private_key_here
VOTER3_PK=0x_voter3_private_key_here
VOTER4_PK=0x_voter4_private_key_here
VOTER5_PK=0x_voter5_private_key_here

# Optional: custom RPC endpoint (defaults to publicnode if unset)
# RPC=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
